comment20.target=int\ getHeight()
comment20.text=\r\n\ Retorna\ la\ altura\ del\ elemento\ en\ pixeles.\r\n
comment21.params=
comment21.target=void\ makeVisible()
comment21.text=\r\n\ Activa\ la\ visibilidad\ del\ elemento\ y\ lo\ dibuja\ en\ su\ posicion\ actual.\r\n
comment22.params=
comment22.target=void\ makeInvisible()
comment22.text=\r\n\ Desactiva\ la\ visibilidad\ del\ elemento\ y\ lo\ borra\ del\ canvas.\r\n
