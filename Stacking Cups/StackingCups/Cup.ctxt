comment11.target=boolean\ canContainLogicalWidth(int)
comment11.text=\r\n\ Retorna\ true\ cuando\ este\ elemento\ puede\ contener\ el\ ancho\ indicado.\r\n
comment12.params=
comment12.target=Cup\ asCup()
comment12.text=\r\n\ Retorna\ la\ vista\ como\ taza\ de\ este\ elemento.\r\n
